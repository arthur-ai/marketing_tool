{
  "type": "json_schema",
  "json_schema": {
    "name": "social_media_post_generation_email_response",
    "description": "Email content generated by the Social Media Post Generation Email agent",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "platform": {
          "type": "string",
          "description": "Always 'email'"
        },
        "content": {
          "type": "string",
          "description": "The generated email body content \u2014 structured with clear headings, short paragraphs, and scannable format"
        },
        "subject_line": {
          "type": "string",
          "description": "Email subject line, 50-60 characters, compelling and clear. For newsletter: value-focused. For promotional: urgent and benefit-focused"
        },
        "call_to_action": {
          "type": "string",
          "description": "The primary CTA for this email \u2014 soft for newsletters, strong conversion-focused for promotional"
        },
        "metadata": {
          "type": "string",
          "description": "Email-specific metadata: email type (newsletter or promotional), send timing recommendation, segmentation notes"
        },
        "email_score": {
          "type": "number",
          "description": "Email quality score from 0 to 100: open rate potential/subject line quality (0-30) + engagement potential/CTA clarity (0-30) + content clarity and scannability (0-20) + conversion or educational value (0-20)"
        },
        "confidence_score": {
          "type": "number",
          "description": "Overall confidence from 0.0 to 1.0"
        },
        "engagement_score": {
          "type": "number",
          "description": "Predicted engagement from 0 to 100 combining open rate and click-through rate potential"
        }
      },
      "required": [
        "platform",
        "content",
        "subject_line",
        "call_to_action",
        "metadata",
        "email_score",
        "confidence_score",
        "engagement_score"
      ],
      "additionalProperties": false
    }
  }
}
