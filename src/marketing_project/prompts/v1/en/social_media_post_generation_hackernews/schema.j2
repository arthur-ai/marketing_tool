{
  "type": "json_schema",
  "json_schema": {
    "name": "social_media_post_generation_hackernews_response",
    "description": "HackerNews post generated by the Social Media Post Generation HackerNews agent",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "platform": {
          "type": "string",
          "description": "Always 'hackernews'"
        },
        "content": {
          "type": "string",
          "description": "The generated HackerNews post content, 500-2000 characters. Technically substantive with no marketing language"
        },
        "call_to_action": {
          "type": "string",
          "description": "Technical discussion CTA \u2014 a question or problem that invites debate, not a promotional prompt"
        },
        "metadata": {
          "type": "string",
          "description": "HackerNews-specific metadata: technical angle used, discussion hooks, submission timing recommendation"
        },
        "hackernews_score": {
          "type": "number",
          "description": "HackerNews quality score from 0 to 100: technical depth and substance (0-40) + discussion potential (0-30) + content clarity and accuracy (0-20) + innovation and merit (0-10)"
        },
        "confidence_score": {
          "type": "number",
          "description": "Overall confidence from 0.0 to 1.0"
        },
        "engagement_score": {
          "type": "number",
          "description": "Predicted HackerNews engagement potential from 0 to 100"
        }
      },
      "required": [
        "platform",
        "content",
        "call_to_action",
        "metadata",
        "hackernews_score",
        "confidence_score",
        "engagement_score"
      ],
      "additionalProperties": false
    }
  }
}
