{
  "type": "json_schema",
  "json_schema": {
    "name": "social_media_post_generation_linkedin_response",
    "description": "LinkedIn post generated by the Social Media Post Generation LinkedIn agent",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "platform": {
          "type": "string",
          "description": "Always 'linkedin'"
        },
        "content": {
          "type": "string",
          "description": "The generated LinkedIn post content, 300-3000 characters. Use line breaks, bullet points, and clear structure"
        },
        "hashtags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Exactly 3-5 relevant hashtags placed at the end of the post \u2014 mix broad industry and niche-specific"
        },
        "call_to_action": {
          "type": "string",
          "description": "Clear call-to-action for engagement or link clicks"
        },
        "metadata": {
          "type": "string",
          "description": "LinkedIn-specific metadata: optimal posting time, audience targeting notes, or engagement hook description"
        },
        "linkedin_score": {
          "type": "number",
          "description": "LinkedIn quality score from 0 to 100: professional tone and appropriateness (0-30) + thought leadership (0-30) + engagement potential (0-20) + content clarity (0-20)"
        },
        "confidence_score": {
          "type": "number",
          "description": "Overall confidence from 0.0 to 1.0"
        },
        "engagement_score": {
          "type": "number",
          "description": "Predicted LinkedIn engagement potential from 0 to 100"
        }
      },
      "required": [
        "platform",
        "content",
        "hashtags",
        "call_to_action",
        "metadata",
        "linkedin_score",
        "confidence_score",
        "engagement_score"
      ],
      "additionalProperties": false
    }
  }
}
