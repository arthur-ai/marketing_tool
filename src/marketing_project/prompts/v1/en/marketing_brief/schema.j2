{
  "type": "json_schema",
  "json_schema": {
    "name": "marketing_brief_response",
    "description": "Comprehensive marketing brief generated by the Marketing Brief agent, driving all downstream content decisions",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "target_audience": {
          "type": "array",
          "description": "Array of 3+ detailed audience personas, each aligned with the main_keyword search intent",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Persona name"
              },
              "role": {
                "type": "string",
                "description": "Job role or life role of this persona"
              },
              "pain_points": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Key pain points and challenges this persona faces"
              },
              "search_behavior": {
                "type": "string",
                "description": "How this persona searches for information related to the main_keyword"
              },
              "decision_drivers": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Factors that drive this persona's decisions"
              }
            },
            "required": [
              "name",
              "role",
              "pain_points",
              "search_behavior",
              "decision_drivers"
            ],
            "additionalProperties": false
          }
        },
        "key_messages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "3-5 core messaging points that incorporate main_keyword themes and resonate with target personas"
        },
        "content_strategy": {
          "type": "string",
          "description": "Strategic content approach centered on main_keyword \u2014 describes positioning, messaging flow, and tactical approach"
        },
        "tone_and_voice": {
          "type": "string",
          "description": "Tone and voice guidelines consistent with brand identity and audience expectations"
        },
        "competitive_angle": {
          "type": "string",
          "description": "How this content differentiates from competitor content and fills identified content gaps"
        },
        "kpis": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Measurable KPIs tied directly to main_keyword performance and business objectives \u2014 all must be SMART"
        },
        "distribution_channels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Channels best suited to reach main_keyword searchers and target personas"
        },
        "content_calendar": {
          "type": "array",
          "description": "Structured content calendar with specific topics, types, and channels per time period",
          "items": {
            "type": "object",
            "properties": {
              "week": {
                "type": "string",
                "description": "Week or time period label"
              },
              "content_type": {
                "type": "string",
                "description": "Type of content (blog post, social media, email, etc.)"
              },
              "topic": {
                "type": "string",
                "description": "Specific topic or angle for this piece"
              },
              "channel": {
                "type": "string",
                "description": "Distribution channel for this content"
              }
            },
            "required": [
              "week",
              "content_type",
              "topic",
              "channel"
            ],
            "additionalProperties": false
          }
        },
        "confidence_score": {
          "type": "number",
          "description": "Overall confidence from 0.0 to 1.0"
        }
      },
      "required": [
        "target_audience",
        "key_messages",
        "content_strategy",
        "tone_and_voice",
        "competitive_angle",
        "kpis",
        "distribution_channels",
        "content_calendar",
        "confidence_score"
      ],
      "additionalProperties": false
    }
  }
}
