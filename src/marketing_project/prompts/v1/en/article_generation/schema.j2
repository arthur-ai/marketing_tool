{
  "type": "json_schema",
  "json_schema": {
    "name": "article_generation_response",
    "description": "Full article output generated by the Article Generation agent, including content, metadata, and quality scores",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "article_title": {
          "type": "string",
          "description": "SEO-optimized article title, 50-60 characters, includes main_keyword preferably in the first 3 words"
        },
        "article_content": {
          "type": "string",
          "description": "Full article in markdown format \u2014 not a summary. Must hit the word count target within 10%"
        },
        "outline": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of H2-level section headers used in the article. Must be content-specific and keyword-rich \u2014 never generic (no 'Introduction', 'Conclusion', etc.)"
        },
        "call_to_action": {
          "type": "string",
          "description": "Call-to-action text, 20-50 words, aligned with marketing brief KPIs"
        },
        "word_count": {
          "type": "number",
          "description": "Actual word count of article_content"
        },
        "hook": {
          "type": "string",
          "description": "Opening hook paragraph, 50-100 words, written to capture reader attention immediately"
        },
        "key_takeaways": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "3-5 key takeaways that reinforce the main messages of the article"
        },
        "confidence_score": {
          "type": "number",
          "description": "Overall confidence from 0.0 to 1.0 reflecting completeness, quality, alignment, and readability"
        },
        "readability_score": {
          "type": "number",
          "description": "Flesch-Kincaid readability score from 0 to 100. Target 60-80 for general audiences"
        },
        "engagement_score": {
          "type": "number",
          "description": "Engagement score from 0 to 100 based on hook strength, structure, visual breaks, and value delivery. Target 70+"
        }
      },
      "required": [
        "article_title",
        "article_content",
        "outline",
        "call_to_action",
        "word_count",
        "hook",
        "key_takeaways",
        "confidence_score",
        "readability_score",
        "engagement_score"
      ],
      "additionalProperties": false
    }
  }
}
