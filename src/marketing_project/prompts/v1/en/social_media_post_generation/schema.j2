{
  "type": "json_schema",
  "json_schema": {
    "name": "social_media_post_generation_response",
    "description": "Platform-optimized social media post generated by the Social Media Post Generation agent",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "platform": {
          "type": "string",
          "description": "The platform this post is generated for: linkedin, hackernews, or email"
        },
        "content": {
          "type": "string",
          "description": "The generated post content \u2014 must meet platform length requirements and use the recommended angle and hook"
        },
        "subject_line": {
          "type": "string",
          "description": "Email subject line (50-60 characters) \u2014 only populated for email platform, empty string for other platforms"
        },
        "hashtags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Hashtags for LinkedIn posts (3-5) \u2014 empty array for non-LinkedIn platforms"
        },
        "call_to_action": {
          "type": "string",
          "description": "The recommended call-to-action for this post"
        },
        "metadata": {
          "type": "string",
          "description": "Additional platform-specific metadata such as optimal posting time, content format notes, or audience targeting hints"
        },
        "confidence_score": {
          "type": "number",
          "description": "Overall confidence from 0.0 to 1.0"
        },
        "engagement_score": {
          "type": "number",
          "description": "Predicted engagement potential from 0 to 100"
        }
      },
      "required": [
        "platform",
        "content",
        "subject_line",
        "hashtags",
        "call_to_action",
        "metadata",
        "confidence_score",
        "engagement_score"
      ],
      "additionalProperties": false
    }
  }
}
