# Development Dockerfile for Marketing Project API
# This Dockerfile is optimized for development with hot-reload
FROM python:3.13-slim

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONPATH=/app/src \
    NUMBA_CACHE_DIR=/tmp

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Set work directory
WORKDIR /app

# Copy requirements and vendored wheels first for better caching
COPY requirements.txt .
COPY vendor/ ./vendor/

# Install vendored wheels then Python dependencies
RUN pip install --no-cache-dir "vendor/arthur_observability_sdk-1.0.0-py3-none-any.whl[openai,langchain,litellm]"
RUN pip install --no-cache-dir -r requirements.txt

# Download UDPipe English model (required for SEO keywords engine)
RUN mkdir -p /root/.udpipe/models && \
    wget -q -O /root/.udpipe/models/english-ewt-ud-2.5-191206.udpipe \
    https://lindat.mff.cuni.cz/repository/xmlui/bitstream/handle/11234/1-3131/english-ewt-ud-2.5-191206.udpipe

# Create necessary directories
# Note: src/ will be mounted as a volume, so we don't install it during build
# Note: logs go to Docker logs (stdout/stderr), not files
RUN mkdir -p /app/uploads /app/cache /app/src

# Dev image runs as root so runtime pip installs (arthur-sdk editable) work without permission issues

# Expose port
EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=30s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8000/api/v1/health || exit 1

# Command will be overridden by docker-compose with --reload flag
CMD ["uvicorn", "src.marketing_project.server:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
